// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")      // ใช้สำหรับการเชื่อมต่อและดึงข้อมูลปกติ
  directUrl = env("POSTGRES_URL_NON_POOLING") // ใช้สำหรับการสร้าง/อัปเดตโครงสร้างตาราง
}

// ตารางเก็บข้อมูลรถ
model Vehicle {
  id        Int      @id @default(autoincrement())
  plate     String   @unique
  brand     String?
  model     String?
  
  logs      MaintenanceLog[]
}

// ตารางเก็บประวัติการแจ้งซ่อม (รองรับครบทุกฟิลด์)
model MaintenanceLog {
  id             Int       @id @default(autoincrement())
  priority       String    // low, normal, high, urgent
  status         String    // reported, assigned, in_progress, etc.
  description    String    // อาการที่แจ้ง
  symptoms       String?   // เก็บเป็น string คั่นด้วยลูกน้ำ เช่น "แอร์ไม่เย็น,มีเสียงดัง"
  projectId      Int?      // ID โครงการ
  projectName    String?   // ชื่อโครงการ
  workshopName   String?   // อู่ / ศูนย์ซ่อม
  technicianName String?   // ชื่อช่าง
  category       String?   // ประเภทงานซ่อม
  locationLabel  String?   // จุดที่จอดซ่อม
  reportedAt     DateTime  @default(now()) // เวลาที่รับแจ้ง
  assignedAt     DateTime? // เวลามอบหมายช่าง
  acceptedAt     DateTime? // เวลาช่างรับงาน
  startedAt      DateTime? // เวลาเริ่มซ่อม
  completedAt    DateTime? // เวลาซ่อมเสร็จ
  dueDate        DateTime? // กำหนดเสร็จ
  cost           Float?    // ค่าซ่อม

  vehicleId      Int
  vehicle        Vehicle   @relation(fields: [vehicleId], references: [id])
}