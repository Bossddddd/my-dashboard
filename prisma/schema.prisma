// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")      // ใช้สำหรับการเชื่อมต่อและดึงข้อมูลปกติ
  directUrl = env("POSTGRES_URL_NON_POOLING") // ใช้สำหรับการสร้าง/อัปเดตโครงสร้างตาราง
}

// ตารางเก็บข้อมูลรถ
model Vehicle {
  id        Int      @id @default(autoincrement())
  plate     String   @unique
  brand     String?
  model     String?
  
  logs      MaintenanceLog[]
}

// ตารางเก็บประวัติการแจ้งซ่อม
model MaintenanceLog {
  id             Int       @id @default(autoincrement())
  priority       String
  status         String
  description    String
  symptoms       String?
  reportedAt     DateTime  @default(now())
  completedAt    DateTime?
  cost           Float?
  technicianName String?

  vehicleId      Int
  vehicle        Vehicle   @relation(fields: [vehicleId], references: [id])
}